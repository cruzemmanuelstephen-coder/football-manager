rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Teams: only the coach (creator) can read/write
    match /teams/{teamId} {
      allow read, write: if request.auth != null && resource.data.coachId == request.auth.uid;
      allow create: if request.auth != null;

      // Players sub-collection
      match /players/{playerId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/teams/$(teamId)).data.coachId == request.auth.uid;
      }

      // Matches sub-collection
      match /matches/{matchId} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/teams/$(teamId)).data.coachId == request.auth.uid;

        // Attendance sub-collection
        match /attendance/{playerId} {
          allow read, write: if request.auth != null && get(/databases/$(database)/documents/teams/$(teamId)).data.coachId == request.auth.uid;
        }
      }
    }
  }
}
