rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Helper functions
    function isTeamAdmin(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data.adminId == request.auth.uid;
    }
    
    function isTeamMember(teamId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == teamId;
    }

    // Teams
    match /teams/{teamId} {
      // Allow any authenticated user to read team basic info (needed for invites/dashboard)
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.adminId == request.auth.uid;

      // Players sub-collection
      match /players/{playerId} {
        allow read: if request.auth != null && (isTeamAdmin(teamId) || isTeamMember(teamId));
        // User can create/update their own player doc (bypasses isTeamMember to avoid race conditions during signup)
        allow write: if request.auth != null && (isTeamAdmin(teamId) || request.auth.uid == playerId);
      }

      // Matches sub-collection
      match /matches/{matchId} {
        allow read: if request.auth != null && (isTeamAdmin(teamId) || isTeamMember(teamId));
        allow write: if request.auth != null && isTeamAdmin(teamId);

        // Attendance sub-collection
        match /attendance/{playerId} {
          allow read: if request.auth != null && (isTeamAdmin(teamId) || isTeamMember(teamId));
          // Admin can write anyone's, player can write their own
          allow write: if request.auth != null && (isTeamAdmin(teamId) || request.auth.uid == playerId);
        }
      }
    }
  }
}
